POSTGRES_PORT=5432
POSTGRES_DB=promo_constructor
POSTGRES_USER=pc_admin
POSTGRES_PASSWORD=change-me-postgres-password

PGADMIN_PORT=5444
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password

OLLAMA_IMAGE=ollama/ollama:0.30.10
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_CPUS=3.0
OLLAMA_MEMORY_LIMIT=2304m
OLLAMA_CONTEXT_LENGTH=1792
OLLAMA_KEEP_ALIVE=10m
OLLAMA_MAX_QUEUE=8
OLLAMA_NUM_PREDICT=112
OLLAMA_SEED=42
OLLAMA_CONNECT_TIMEOUT_SECONDS=3
OLLAMA_READ_TIMEOUT_SECONDS=120
OLLAMA_QUEUE_WAIT_TIMEOUT_SECONDS=5
OLLAMA_USER_MESSAGE_MAX_CHARS=2600

BACKEND_IMAGE=promo-constructor-backend:latest
FRONTEND_IMAGE=promo-constructor-frontend:latest

BACKEND_PROJECT_NAME=Promo Constructor Backend
BACKEND_VERSION=0.1.0
BACKEND_ENVIRONMENT=production
BACKEND_API_V1_PREFIX=/api/v1
BACKEND_SECRET_KEY=change-me-long-random-secret
BACKEND_JWT_ALGORITHM=HS256
BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=7200
BACKEND_REFRESH_TOKEN_EXPIRE_MINUTES=7200
BACKEND_ACCESS_COOKIE_NAME=pc_access_token
BACKEND_REFRESH_COOKIE_NAME=pc_refresh_token
BACKEND_COOKIE_SECURE=true
BACKEND_COOKIE_SAMESITE=lax
BACKEND_CORS_ORIGINS=["https://your-domain.example"]
API_ADMIN_PROTECTION_ENABLED=true
API_ADMIN_KEY=change-me-pre-shared-api-admin-key
FRONTEND_INTERNAL_API_KEY=change-me-long-random-frontend-proxy-key
VITE_LLM_RECOMMENDATIONS_ENABLED=true

BACKEND_PORT=8000
FRONTEND_HTTP_PORT=80
FRONTEND_HTTPS_PORT=443
FRONTEND_SERVER_NAMES=your-domain.example
CERTBOT_EMAIL=admin@your-domain.example
CERTBOT_CERT_NAME=your-domain.example
